{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "paths": {
      "~/*": ["./app/*"],
      "zk-eidas-wasm": ["./pkg/zk-eidas-wasm.js"]
    }
  },
  "include": ["app/**/*", "*.ts"],
  "exclude": ["app/**/*.test.ts"]
}
